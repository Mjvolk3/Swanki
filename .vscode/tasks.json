{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "setup: worktree",
            "type": "shell",
            "command": "./scripts/setup-worktree.sh",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            }
        },
        {
            "label": "Paper: compile",
            "type": "shell",
            "command": "bash notes/assets/publish/scripts/compile_paper.sh",
            "problemMatcher": []
        },
        {
            "label": "Pandoc: quick-pdf",
            "type": "shell",
            "command": "cd ./notes && pandoc -F mermaid-filter -s ${file} -o ${fileDirname}/assets/pdf-output/${fileBasenameNoExtension}.pdf --pdf-engine=xelatex -V geometry:'top=2cm, bottom=1.5cm, left=2cm, right=2cm' --strip-comments && cd ..",
            "problemMatcher": []
        },
        {
            "label": "Pandoc: quick-landscape-pdf",
            "type": "shell",
            "command": "cd ./notes && pandoc -F mermaid-filter -s ${file} -o ${fileDirname}/assets/pdf-output/${fileBasenameNoExtension}.pdf --pdf-engine=xelatex -V geometry:'top=0.1cm, bottom=0.1cm, left=0.1cm, right=0.1cm,landscape' --strip-comments && cd ..",
            "problemMatcher": []
        },
        {
            "label": "Pandoc: bib-pdf",
            "type": "shell",
            "command": "cd ./notes && pandoc -F mermaid-filter -s ${file} -o ${fileDirname}/assets/pdf-output/${fileBasenameNoExtension}.pdf --pdf-engine=xelatex --citeproc --bibliography assets/publish/bib/bib.bib --metadata csl=assets/publish/bib/nature.csl -V geometry:'top=2cm, bottom=1.5cm, left=2cm, right=2cm' --strip-comments && cd ..",
            "problemMatcher": []
        },
        {
            "label": "Pandoc: bib-tex-pdf",
            "type": "shell",
            "command": "./notes/assets/publish/scripts/bib_tex_pdf.sh ${file} ${fileDirname} ${fileBasenameNoExtension}",
            "problemMatcher": []
        },
        {
            "label": "Pandoc: bib-tex-pdf-landscape",
            "type": "shell",
            "command": "./notes/assets/publish/scripts/bib_tex_pdf_landscape.sh ${file} ${fileDirname} ${fileBasenameNoExtension}",
            "problemMatcher": []
        },
        {
            "label": "Pandoc: bib-tex-docx",
            "type": "shell",
            "command": "./notes/assets/publish/scripts/bib_tex_docx.sh ${file} ${fileDirname} ${fileBasenameNoExtension}",
            "problemMatcher": []
        },
        {
            "label": "ruff: check file",
            "type": "shell",
            "command": "ruff",
            "args": ["check", "--fix", "${file}"],
            "problemMatcher": [],
            "group": { "kind": "build", "isDefault": true }
        },
        {
            "label": "ruff: format file",
            "type": "shell",
            "command": "ruff",
            "args": ["format", "${file}"],
            "problemMatcher": [],
            "group": { "kind": "build", "isDefault": true }
        },
        {
            "label": "mypy: file",
            "type": "shell",
            "command": "mypy ${file}",
            "problemMatcher": []
        },
        {
            "label": "mypy: workspace",
            "type": "shell",
            "command": "mypy swanki",
            "problemMatcher": []
        },
        {
            "label": "dmypy: restart",
            "type": "shell",
            "command": "bash mypy/dmypy_restart.sh",
            "problemMatcher": []
        },
        {
            "label": "swanki: pyreverse UML class diagram",
            "type": "shell",
            "command": "${workspaceFolder}/notes/assets/scripts/run_pyreverse.sh",
            "args": ["${file}"],
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "pyreverse: UML class diagram",
            "type": "shell",
            "command": "/Users/michaelvolk/opt/miniconda3/envs/swanki/bin/python",
            "args": [
                "/Users/michaelvolk/opt/miniconda3/envs/swanki/bin/pyreverse",
                "-o", "png", "-p", "uml_temp", "${file}"
            ],
            "problemMatcher": [],
            "group": "build"
        },
        {
            "label": "swk-fm: add frontmatter",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/notes/assets/scripts/add_frontmatter.py",
                "${file}"
            ],
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "swk-tf: create test file",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/notes/assets/scripts/create_python_test_file.py",
                "create",
                "${file}"
            ],
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "swk-rm: delete file",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/notes/assets/scripts/delete_file_and_open_related.py",
                "${file}"
            ],
            "problemMatcher": [],
            "group": { "kind": "build", "isDefault": true },
            "presentation": {
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            }
        },
        {
            "label": "swk-mv: move file",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/notes/assets/scripts/python_move_dendron_pytest.py",
                "${file}",
                "${input:moveDestinationPath}"
            ],
            "problemMatcher": [],
            "presentation": { "reveal": "always" }
        },
        {
            "label": "swk-or: open related src",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/notes/assets/scripts/from_note_open_related_src.py",
                "${file}"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "swk-test-unit",
            "type": "shell",
            "command": "/Users/michaelvolk/opt/miniconda3/envs/swanki/bin/python -m pytest tests/ -x",
            "problemMatcher": []
        },
        {
            "label": "swk-cov-run",
            "type": "shell",
            "command": "/Users/michaelvolk/opt/miniconda3/envs/swanki/bin/python -m coverage run -m pytest tests/ -x && /Users/michaelvolk/opt/miniconda3/envs/swanki/bin/python -m coverage report",
            "problemMatcher": []
        },
        {
            "label": "swk-cov-html",
            "type": "shell",
            "command": "/Users/michaelvolk/opt/miniconda3/envs/swanki/bin/python -m coverage run -m pytest tests/ -x && /Users/michaelvolk/opt/miniconda3/envs/swanki/bin/python -m coverage html && code htmlcov/index.html",
            "problemMatcher": []
        },
        {
            "label": "pytest: coverage",
            "type": "shell",
            "command": "/Users/michaelvolk/opt/miniconda3/envs/swanki/bin/python /Users/michaelvolk/opt/miniconda3/envs/swanki/bin/pytest --cov=swanki --cov-report html tests/",
            "problemMatcher": []
        },
        {
            "label": "sphinx: build html",
            "type": "shell",
            "command": "make -C docs html",
            "problemMatcher": []
        },
        {
            "label": "dendron: tree",
            "type": "shell",
            "command": "bash scripts/dendron-tree.sh -L ${input:dendronTreeDepth}",
            "problemMatcher": []
        },
        {
            "label": "dendron: open random notes",
            "type": "shell",
            "command": "python notes/assets/scripts/open_random_notes.py -n ${input:openRandomNotes} -d ${workspaceFolder}/notes",
            "problemMatcher": []
        },
        {
            "label": "Dendron: export pod md",
            "type": "shell",
            "command": "bash ./notes/assets/publish/scripts/export_pod_md.sh ${file}",
            "problemMatcher": []
        },
        {
            "label": "Dendron: export pod md + pdf",
            "type": "shell",
            "command": "bash ./notes/assets/publish/scripts/export_pod_md.sh ${file} && ./notes/assets/publish/scripts/bib_tex_pdf.sh ./notes/assets/export-pod-md/${fileBasename} ./notes/assets/export-pod-md ${fileBasenameNoExtension} pdf-pod-output",
            "problemMatcher": []
        },
        {
            "label": "git: open all changed files",
            "type": "shell",
            "command": "code $(git status -uall --porcelain | awk '{print $NF}')",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Open External Terminal",
            "type": "shell",
            "command": "./notes/assets/scripts/open-external-terminal.sh",
            "problemMatcher": []
        },
        {
            "label": "tcdb: build linux-arm",
            "type": "shell",
            "command": "osascript",
            "args": [
                "-e",
                "tell application \"Terminal\" to do script \"bash /Users/michaelvolk/Documents/projects/swanki/database/build/build_linux-arm.sh\""
            ],
            "problemMatcher": [],
            "group": { "kind": "build", "isDefault": true }
        },
        {
            "label": "tcdb: build linux-arm fresh",
            "type": "shell",
            "command": "osascript",
            "args": [
                "-e",
                "tell application \"Terminal\" to do script \"bash /Users/michaelvolk/Documents/projects/swanki/database/build/build-image-fresh_linux-arm.sh\""
            ],
            "problemMatcher": [],
            "group": { "kind": "build", "isDefault": true }
        },
        {
            "label": "swanki: publish pypi",
            "type": "shell",
            "command": "source ${workspaceFolder}/notes/assets/scripts/swanki_publish_pypi.sh",
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "dendronTreeDepth",
            "description": "Tree depth",
            "type": "pickString",
            "options": ["1", "2", "3", "4", "5"],
            "default": "2"
        },
        {
            "id": "openRandomNotes",
            "description": "Number of random notes to open",
            "type": "pickString",
            "options": ["1", "2", "4", "8", "16"]
        },
        {
            "id": "moveDestinationPath",
            "type": "promptString",
            "description": "Enter destination path for move/rename:"
        }
    ]
}
